<!DOCTYPE html>
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Login & Registro</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        .card {
            transition: all 0.5s ease;
            transform-style: preserve-3d;
        }
        .card-hidden {
            opacity: 0;
            transform: translateX(50px);
            pointer-events: none;
            position: absolute;
        }
        .card-visible {
            opacity: 1;
            transform: translateX(0);
            pointer-events: all;
        }
        .floating {
            animation: floating 3s ease-in-out infinite;
        }
        @keyframes floating {
            0% { transform: translateY(0px); }
            50% { transform: translateY(-10px); }
            100% { transform: translateY(0px); }
        }
        .input-field {
            transition: all 0.3s ease;
        }
        .input-field:focus {
            box-shadow: 0 0 0 2px rgba(99, 102, 241, 0.5);
        }
    </style>
</head>
{% block body %}

    <body class="bg-gradient-to-br from-indigo-900 to-purple-800 min-h-screen flex items-center justify-center p-4">
    <div class="relative w-full max-w-md">
    {% block loginCard %}
        <!-- Card de Login -->
        <div id="login-card" class="card card-visible bg-white rounded-2xl shadow-2xl overflow-hidden">
            <div class="absolute top-0 left-0 w-full h-2 bg-gradient-to-r from-pink-500 to-indigo-500"></div>

            <div class="p-8">
                <div class="text-center mb-8">
                    <h1 class="text-3xl font-bold text-gray-800 mb-2">Bem-vindo de volta</h1>
                    <p class="text-gray-600">Faça login para acessar sua conta</p>
                </div>

                <form class="space-y-6" method="post" action="{{ path('app_login') }}">
                    {% if error %}
                        <div class="text-red-500 mb-2">{{ error.messageKey|trans(error.messageData, 'security') }}</div>
                    {% endif %}
                    <div class="mb-4 relative">
                        <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                            <i class="fas fa-envelope text-gray-400"></i>
                        </div>
                        <input type="email" placeholder='exemplo@exemplo.com.br' value="{{ last_username }}" name="email" id="inputEmail" class="input-field pl-10 w-full px-4 py-3 rounded-lg border border-gray-300 focus:outline-none focus:border-indigo-500" autocomplete="email" required autofocus>
                    </div>

                    <div class="mb-4 relative">
                        <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                            <i class="fas fa-lock text-gray-400"></i>
                        </div>
                        <input type="password" placeholder='Sua Senha' name="password" id="inputPassword" class="input-field pl-10 w-full px-4 py-3 rounded-lg border border-gray-300 focus:outline-none focus:border-indigo-500" autocomplete="current-password" required>
                    </div>

                    <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">



                    <div class="mb-6 flex items-center justify-between">
                        <div class="flex items-center">
                            <input id="remember-me" type="checkbox" class="h-4 w-4 text-indigo-600 focus:ring-indigo-500 border-gray-300 rounded">
                            <label for="remember-me" class="ml-2 block text-sm text-gray-700">Lembrar-me</label>
                        </div>
                        <a href="#" class="text-sm text-indigo-600 hover:text-indigo-500">Esqueceu a senha?</a>
                    </div>

                    <button type="submit" class="w-full bg-gradient-to-r from-indigo-500 to-purple-600 text-white py-3 px-4 rounded-lg font-semibold hover:opacity-90 transition duration-300 shadow-lg">
                        Entrar
                    </button>
                </form>

                <div class="mt-6 text-center">
                    <p class="text-gray-600">Não tem uma conta?
                        <a href="#" id="show-register" class="text-indigo-600 font-medium hover:text-indigo-500">Registre-se</a>
                    </p>
                </div>

                <div class="mt-6 border-t border-gray-200 pt-6">
                    <div class="flex justify-center space-x-4">
                        <button class="w-10 h-10 rounded-full bg-blue-100 flex items-center justify-center text-blue-600 hover:bg-blue-200 transition">
                            <i class="fab fa-facebook-f"></i>
                        </button>
                        <button class="w-10 h-10 rounded-full bg-red-100 flex items-center justify-center text-red-600 hover:bg-red-200 transition">
                            <i class="fab fa-google"></i>
                        </button>
                        <button class="w-10 h-10 rounded-full bg-gray-100 flex items-center justify-center text-gray-600 hover:bg-gray-200 transition">
                            <i class="fab fa-github"></i>
                        </button>
                    </div>
                </div>
            </div>
        </div>
    {% endblock %}

        {% block registerCard %}
            <!-- Card de Registro -->
            <div id="register-card" class="card card-hidden bg-white rounded-2xl shadow-2xl overflow-hidden">
                <div class="absolute top-0 left-0 w-full h-2 bg-gradient-to-r from-purple-500 to-pink-500"></div>

                <div class="p-8">
                    <div class="text-center mb-8">
                        <h1 class="text-3xl font-bold text-gray-800 mb-2">Crie sua conta</h1>
                        <p class="text-gray-600">Preencha os campos para se registrar</p>
                    </div>

                    {{ form_start(registrationForm, {
                        attr: {
                            class: 'space-y-6',
                            action: path('app_login'),
                            method: 'POST'
                        }
                    }) }}
                    {{ form_errors(registrationForm) }}
                        <!--
                        <div class="relative">
                            <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                                <i class="fas fa-user text-gray-400"></i>
                            </div>
                            <input type="text" placeholder="Seu nome" class="input-field pl-10 w-full px-4 py-3 rounded-lg border border-gray-300 focus:outline-none focus:border-indigo-500">
                        </div>
                        -->
                        <div class="relative">
                            <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                                <i class="fas fa-envelope text-gray-400"></i>
                            </div>
                            {{ form_widget(registrationForm.email, {
                                'attr': {
                                    'placeholder': 'Seu e-mail',
                                    'class': 'input-field pl-10 w-full px-4 py-3 rounded-lg border border-gray-300 focus:outline-none focus:border-indigo-500'
                                }
                            }) }}
                        </div>

                        <div class="relative">
                            <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                                <i class="fas fa-lock text-gray-400"></i>
                            </div>

                            {{ form_widget(registrationForm.password, {
                                'attr': {
                                    'placeholder': 'Sua senha',
                                    'class': 'input-field pl-10 w-full px-4 py-3 rounded-lg border border-gray-300 focus:outline-none focus:border-indigo-500'
                                }
                            }) }}
                            {{ form_errors(registrationForm.password) }}

                        </div>

                    <div class=" flex flex-col">
                        <label class="block text-sm font-medium text-gray-700 mb-1">Tipo de conta</label>
                        {{ form_widget(registrationForm.roles, {
                            'attr': {
                                'class': 'w-full input-field px-4 py-3 rounded-lg border border-gray-300 focus:outline-none focus:border-indigo-500'
                            }
                        }) }}
                    </div>

                        <div class="flex items-center">
                            <input id="terms" type="checkbox" class="h-4 w-4 text-indigo-600 focus:ring-indigo-500 border-gray-300 rounded">
                            <label for="terms" class="ml-2 block text-sm text-gray-700">
                                Eu concordo com os <a href="#" class="text-indigo-600 hover:text-indigo-500">Termos de Serviço</a>
                            </label>
                        </div>

                        <button type="submit" class="w-full bg-gradient-to-r from-purple-500 to-pink-600 text-white py-3 px-4 rounded-lg font-semibold hover:opacity-90 transition duration-300 shadow-lg">
                            Registrar
                        </button>

                        {{ form_rest(registrationForm) }}

                        {{ form_end(registrationForm) }}
                    </form>

                    <div class="mt-6 text-center">
                        <p class="text-gray-600">Já tem uma conta?
                            <a href="#" id="show-login" class="text-indigo-600 font-medium hover:text-indigo-500">Faça login</a>
                        </p>
                    </div>
                </div>
            </div>
        {% endblock %}

        <!-- Elemento decorativo -->
        <div class="absolute -top-20 -right-20 w-40 h-40 bg-purple-300 rounded-full opacity-20 mix-blend-overlay floating"></div>
        <div class="absolute -bottom-20 -left-20 w-40 h-40 bg-indigo-300 rounded-full opacity-20 mix-blend-overlay floating" style="animation-delay: 1s;"></div>
    </div>

    <script>
        document.addEventListener('DOMContentLoaded', function() {
            const loginCard = document.getElementById('login-card');
            const registerCard = document.getElementById('register-card');
            const showRegister = document.getElementById('show-register');
            const showLogin = document.getElementById('show-login');

            showRegister.addEventListener('click', function(e) {
                e.preventDefault();
                loginCard.classList.remove('card-visible');
                loginCard.classList.add('card-hidden');

                registerCard.classList.remove('card-hidden');
                registerCard.classList.add('card-visible');
            });

            showLogin.addEventListener('click', function(e) {
                e.preventDefault();
                registerCard.classList.remove('card-visible');
                registerCard.classList.add('card-hidden');

                loginCard.classList.remove('card-hidden');
                loginCard.classList.add('card-visible');
            });
        });
    </script>
    </body>
{% endblock %}