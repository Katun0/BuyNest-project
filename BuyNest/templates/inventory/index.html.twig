{% extends 'base.html.twig' %}

{% block title %}BN - Inventário{% endblock %}

{% block StyleSheets %}

{% endblock %}

{% block body %}
    <div id="flash-messages">
        {% for label, messages in app.flashes %}
            {% for message in messages %}
                <div class="bg-{{ label == 'success' ? 'green' : 'red' }}-100 border border-{{ label == 'success' ? 'green' : 'red' }}-400 text-{{ label == 'success' ? 'green' : 'red' }}-700 px-4 py-3 rounded relative mb-4" role="alert">
                    {{ message }}
                </div>
            {% endfor %}
        {% endfor %}
    </div>

    <div id="inventory-form">
        {% include 'inventory/_form.html.twig' with {'form': form} %}
    </div>

    <div id="inventory-form-errors"></div>

    <div class="flex justify-between items-center my-6">
        <h2 class="text-xl font-semibold">Lista de Itens de Inventário</h2>
    </div>

    <div class="overflow-x-auto">
        <table class="min-w-full divide-y divide-gray-200 border border-gray-300">
            <thead class="bg-gray-100">
            <tr>
                <th class="px-4 py-2 text-left text-sm font-medium text-gray-700">ID</th>
                <th class="px-4 py-2 text-left text-sm font-medium text-gray-700">Produto</th>
                <th class="px-4 py-2 text-left text-sm font-medium text-gray-700">Loja</th>
                <th class="px-4 py-2 text-left text-sm font-medium text-gray-700">Quantidade</th>
                <th class="px-4 py-2 text-left text-sm font-medium text-gray-700">Preço</th>
                <th class="px-4 py-2 text-left text-sm font-medium text-gray-700">Ações</th>
            </tr>
            </thead>
            <tbody id="inventory-table-body" class="bg-white divide-y divide-gray-200">
                {% include 'inventory/_inventory_table.html.twig' with {'inventoryItems': inventoryItems} %}
            </tbody>
        </table>
    </div>

    <div id="editModal" class="fixed inset-0 bg-gray-600 bg-opacity-50 overflow-y-auto h-full w-full hidden">
        <div class="relative top-20 mx-auto p-5 border w-96 shadow-lg rounded-md bg-white">
            <div class="mt-3">
                <div class="flex justify-between items-center pb-3">
                    <h3 class="text-lg leading-6 font-medium text-gray-900">Editar Item de Inventário</h3>
                    <button onclick="closeEditModal()" class="text-gray-400 hover:text-gray-500">
                        <span class="text-2xl">&times;</span>
                    </button>
                </div>
                <div id="modalContent">

                </div>
            </div>
        </div>
    </div>
    {% block javascripts %}
        <!-- Include vanilla-masker library -->
        <script src="https://unpkg.com/vanilla-masker@1.2.0/lib/vanilla-masker.js"></script>


        <script>
            document.addEventListener('DOMContentLoaded', function() {
                // Set up Turbo Stream event listeners
                document.addEventListener('turbo:before-stream-render', function(event) {
                    const targetElement = document.getElementById(event.target.target);
                    if (targetElement && event.target.action === 'append') {
                        if (targetElement.id === 'inventory-table-body') {
                            setTimeout(() => {
                                setupEditButtons();
                                applyInputMasks();
                            }, 0);
                        }
                    }
                });

                // Set up edit buttons
                setupEditButtons();

                // Adicionar listener para fechar o modal
                const modal = document.getElementById('editModal');
                if (modal) {
                    modal.addEventListener('click', function(e) {
                        if (e.target === this) {
                            closeEditModal();
                        }
                    });
                }

                // Apply input masks to the main form
                applyInputMasks();
            });

            function setupEditButtons() {
                // Adicionar listeners para todos os botões de edição
                const editButtons = document.querySelectorAll('.edit-button');
                editButtons.forEach(button => {
                    button.addEventListener('click', function() {
                        const inventoryId = this.getAttribute('data-inventory-id');
                        openEditModal(inventoryId);
                    });
                });
            }

            function openEditModal(inventoryId) {
                const modal = document.getElementById('editModal');
                if (modal) {
                    modal.classList.remove('hidden');

                    // Carregar o formulário via Turbo Stream
                    fetch(`/inventory/${inventoryId}/edit-form`, {
                        headers: {
                            'Accept': 'text/vnd.turbo-stream.html, text/html, application/xhtml+xml'
                        }
                    })
                        .then(response => response.text())
                        .then(html => {
                            const modalContent = document.getElementById('modalContent');
                            if (modalContent) {
                                modalContent.innerHTML = html;
                                // Apply masks to the edit form after it's loaded
                                applyInputMasks();
                            }
                        })
                        .catch(error => {
                            console.error('Erro ao carregar o formulário:', error);
                        });
                }
            }

            function closeEditModal() {
                const modal = document.getElementById('editModal');
                if (modal) {
                    modal.classList.add('hidden');
                }
            }

            function applyInputMasks() {

                // Money mask
                const priceInputs = document.querySelectorAll('.price-mask');
                priceInputs.forEach(input => {
                    input.addEventListener('input', function() {
                        // Remove non-numeric characters
                        let value = this.value.replace(/\D/g, '');

                        // Convert to number and format as currency
                        if (value) {
                            // Convert to decimal (divide by 100 to get the decimal value)
                            value = parseFloat(value) / 100;
                            // Format as Brazilian currency (R$)
                            this.value = value.toLocaleString('pt-BR', {
                                style: 'currency',
                                currency: 'BRL',
                                minimumFractionDigits: 2
                            });
                        }
                    });
                    // Trigger input event to apply mask to existing values
                    input.dispatchEvent(new Event('input'));
                });

            }

        </script>

    {% endblock %}


{% endblock %}
