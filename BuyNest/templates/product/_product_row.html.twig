<tr id="product_{{ product.id }}" class="hover:bg-black hover:bg-opacity-25">
    <td class="px-4 py-2 text-sm">{{ product.id }}</td>
    <td class="px-4 py-2 text-sm">
        {% if product.photo %}
            <img src="{{ asset('uploads/products/' ~ product.photo) }}" alt="{{ product.name }}" class="h-10 w-10 object-cover rounded-lg">
        {% else %}
            <div class="h-10 w-10 bg-gray-200 rounded-lg flex items-center justify-center">
                <span class="text-gray-500">Sem foto</span>
            </div>
        {% endif %}
    </td>
    <td class="px-4 py-2 text-sm">{{ product.name }}</td>
    <td class="px-4 py-2 text-sm">{{ product.description }}</td>
    <td class="px-4 py-2 text-sm">{{ product.category.name }}</td>
    <td class="px-4 py-2 text-sm">{{ product.supplier.name }}</td>
    <td class="px-4 py-2 text-sm">{{ product.active ? 'Sim' : 'Não' }}</td>
    <td class="px-4 py-2 text-sm">
        <button type="button"
                class="edit-button border border-purple-400 text-white bg-purple-600 rounded px-3 py-1 hover:bg-purple-100"
                data-product-id="{{ product.id }}">
            Editar
        </button>
    </td>
</tr>
