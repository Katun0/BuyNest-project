{% extends 'base.html.twig' %}

{% block title %} BN - Home {% endblock %}

{% block content %}
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
{% endblock %}

{% block body %}
    <div class="bg-white" x-data="{ modalOpen: false, modalProduct: {} }">
        <div class="max-w-7xl mx-auto px-4 py-12 sm:px-6 lg:px-8">
            <h2 class="text-3xl font-bold text-gray-800 mb-8">Catálogo de Produtos</h2>

            <div class="grid gap-8 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4">
                {% for product in products %}
                    {% set lowestPrice = null %}
                    {% for inventory in product.inventories %}
                        {% if lowestPrice is null or inventory.price < lowestPrice %}
                            {% set lowestPrice = inventory.price %}
                        {% endif %}
                    {% endfor %}
                    {% set priceFormatted = lowestPrice is not null ? ('R$ ' ~ lowestPrice|number_format(2, ',', '.')) : 'Indisponível' %}
                    {% set stock = quantities[product.id]|default('Fora de estoque') %}
                    {% set isAvailable = lowestPrice is not null and stock != 'Fora de estoque' %}
                    {% set photo = product.photo ? asset('uploads/products/' ~ product.photo) : asset('uploads/products/placeholder.png') %}

                    <div class="bg-white border border-gray-200 rounded-xl shadow-sm hover:shadow-lg transition overflow-hidden flex flex-col">
                        <img src="{{ photo }}" alt="{{ product.name }}" class="object-cover h-56 w-full">
                        <div class="p-4 flex-1 flex flex-col justify-between">
                            <div>
                                <h3 class="text-lg font-semibold text-gray-800">{{ product.name }}</h3>
                                <p class="text-sm text-gray-500">{{ product.category.name }}</p>
                                <p class="text-sm {{ isAvailable ? 'text-green-600 font-medium' : 'text-red-500' }}">
                                    {{ priceFormatted }}
                                </p>
                                <p class="text-xs text-gray-500">Estoque: {{ stock }}</p>
                            </div>
                            <div class="mt-4 flex flex-col gap-2">
                                <button
                                        @click="modalProduct = {
                  name: '{{ product.name|e('js') }}',
                  description: '{{ product.description|e('js') }}',
                  category: '{{ product.category.name|e('js') }}',
                  photo: '{{ photo }}',
                  price: '{{ priceFormatted }}',
                  stock: '{{ stock }}'
                }; modalOpen = true"
                                        class="w-full bg-indigo-600 hover:bg-indigo-700 text-white py-2 rounded text-sm font-semibold transition">
                                    Ver Detalhes
                                </button>

                                {% if isAvailable %}
                                    <a href="{{ path('app_cart_add', {'id': product.id}) }}"
                                       class="w-full bg-green-600 hover:bg-green-700 text-white py-2 rounded text-sm font-semibold transition text-center">
                                        Adicionar ao Carrinho
                                    </a>
                                {% else %}
                                    <span class="w-full py-2 text-center text-gray-400 text-sm border border-gray-300 rounded">
                  Indisponível
                </span>
                                {% endif %}
                            </div>
                        </div>
                    </div>
                {% else %}
                    <div class="col-span-full text-center py-8">
                        <p class="text-gray-500">Nenhum produto disponível no momento.</p>
                    </div>
                {% endfor %}
            </div>
        </div>

        <!-- Modal -->
        <div
                x-show="modalOpen"
                x-transition
                class="fixed inset-0 z-50 bg-black bg-opacity-50 flex items-center justify-center px-4"
        >
            <div class="bg-white w-full max-w-lg max-h-[80vh] overflow-y-auto rounded-xl shadow-lg p-6 relative" @click.outside="modalOpen = false">
            <button class="absolute top-2 right-3 text-gray-500 hover:text-gray-800" @click="modalOpen = false">
                    <i class="fas fa-times"></i>
                </button>
                <template x-if="modalProduct">
                    <div>
                        <img :src="modalProduct.photo" alt="" class="w-full object-cover rounded-lg mb-4 ">
                        <h2 class="text-2xl font-bold text-gray-800" x-text="modalProduct.name"></h2>
                        <p class="text-gray-600 mt-2 text-sm" x-text="modalProduct.description"></p>
                        <p class="text-sm text-gray-500 mt-2" x-text="'Categoria: ' + modalProduct.category"></p>
                        <p class="text-sm text-gray-500" x-text="'Estoque: ' + modalProduct.stock"></p>
                        <p class="text-lg font-semibold text-indigo-600 mt-2" x-text="modalProduct.price"></p>
                    </div>
                </template>
            </div>
        </div>
    </div>
{% endblock %}
