{% extends 'base.html.twig' %}

{% block title %}BN - Fornecedores{% endblock %}

{% block StyleSheets %}

{% endblock %}

{% block body %}
    <div id="flash-messages">
        {% for label, messages in app.flashes %}
            {% for message in messages %}
                <div class="bg-{{ label == 'success' ? 'green' : 'red' }}-100 border border-{{ label == 'success' ? 'green' : 'red' }}-400 text-{{ label == 'success' ? 'green' : 'red' }}-700 px-4 py-3 rounded relative mb-4" role="alert">
                    {{ message }}
                </div>
            {% endfor %}
        {% endfor %}
    </div>

    <div id="supplier-form">
        {% include 'supplier/_form.html.twig' with {'form': form} %}
    </div>

    <div id="supplier-form-errors"></div>

    <h2 class="text-xl font-semibold my-6">Lista de Fornecedores</h2>

    <div class="overflow-x-auto">
        <table class="min-w-full divide-y divide-gray-200 border border-gray-300">
            <thead class="bg-gray-100">
            <tr>
                <th class="px-4 py-2 text-left text-sm font-medium text-gray-700">ID</th>
                <th class="px-4 py-2 text-left text-sm font-medium text-gray-700">Nome</th>
                <th class="px-4 py-2 text-left text-sm font-medium text-gray-700">Razão Social</th>
                <th class="px-4 py-2 text-left text-sm font-medium text-gray-700">CPF/CNPJ</th>
                <th class="px-4 py-2 text-left text-sm font-medium text-gray-700">Telefone</th>
                <th class="px-4 py-2 text-left text-sm font-medium text-gray-700">CEP</th>
                <th class="px-4 py-2 text-left text-sm font-medium text-gray-700">Endereço</th>
                <th class="px-4 py-2 text-left text-sm font-medium text-gray-700">Número</th>
                <th class="px-4 py-2 text-left text-sm font-medium text-gray-700">Cidade</th>
                <th class="px-4 py-2 text-left text-sm font-medium text-gray-700">Ativo</th>
                <th class="px-4 py-2 text-left text-sm font-medium text-gray-700">Ações</th>
            </tr>
            </thead>
            <tbody id="suppliers-table-body" class="bg-white divide-y divide-gray-200">
            {% for supplier in suppliers %}
                {% include 'supplier/_supplier_row.html.twig' with {'supplier': supplier} %}
            {% endfor %}
            </tbody>
        </table>
    </div>

    <div id="editModal" class="fixed inset-0 bg-gray-600 bg-opacity-50 overflow-y-auto h-full w-full hidden">
        <div class="relative top-20 mx-auto p-5 border w-96 shadow-lg rounded-md bg-white">
            <div class="mt-3">
                <div class="flex justify-between items-center pb-3">
                    <h3 class="text-lg leading-6 font-medium text-gray-900">Editar Fornecedor</h3>
                    <button onclick="closeEditModal()" class="text-gray-400 hover:text-gray-500">
                        <span class="text-2xl">&times;</span>
                    </button>
                </div>
                <div id="modalContent">

                </div>
            </div>
        </div>
    </div>
    {% block javascripts %}
        <!-- Include vanilla-masker library -->
        <script src="https://unpkg.com/vanilla-masker@1.2.0/lib/vanilla-masker.js"></script>

        <script>
            document.addEventListener('DOMContentLoaded', function() {
                // Set up Turbo Stream event listeners
                document.addEventListener('turbo:before-stream-render', function(event) {
                    const targetElement = document.getElementById(event.target.target);
                    if (targetElement && event.target.action === 'append') {
                        if (targetElement.id === 'suppliers-table-body') {
                            setTimeout(() => {
                                applyInputMasks();
                                setupEditButtons();
                            }, 0);
                        }
                    }
                });

                // Set up edit buttons
                setupEditButtons();

                // Adicionar listener para fechar o modal
                const modal = document.getElementById('editModal');
                if (modal) {
                    modal.addEventListener('click', function(e) {
                        if (e.target === this) {
                            closeEditModal();
                        }
                    });
                }

                // Apply input masks to the main form
                applyInputMasks();
            });

            function setupEditButtons() {
                // Adicionar listeners para todos os botões de edição
                const editButtons = document.querySelectorAll('.edit-button');
                editButtons.forEach(button => {
                    button.addEventListener('click', function() {
                        const supplierId = this.getAttribute('data-supplier-id');
                        openEditModal(supplierId);
                    });
                });
            }

            function openEditModal(supplierId) {
                const modal = document.getElementById('editModal');
                if (modal) {
                    modal.classList.remove('hidden');

                    // Carregar o formulário via Turbo Stream
                    fetch(`/supplier/${supplierId}/edit-form`, {
                        headers: {
                            'Accept': 'text/vnd.turbo-stream.html, text/html, application/xhtml+xml'
                        }
                    })
                        .then(response => response.text())
                        .then(html => {
                            const modalContent = document.getElementById('modalContent');
                            if (modalContent) {
                                modalContent.innerHTML = html;
                                // Apply masks to the edit form after it's loaded
                                applyInputMasks();
                            }
                        })
                        .catch(error => {
                            console.error('Erro ao carregar o formulário:', error);
                        });
                }
            }

            function closeEditModal() {
                const modal = document.getElementById('editModal');
                if (modal) {
                    modal.classList.add('hidden');
                }
            }

            // Function to apply input masks
            function applyInputMasks() {
                // CPF/CNPJ mask
                const cpfCnpjInputs = document.querySelectorAll('.cpf-cnpj-mask');
                cpfCnpjInputs.forEach(input => {
                    input.addEventListener('input', function() {
                        const value = this.value.replace(/\D/g, '');
                        if (value.length <= 11) {
                            // CPF mask: 000.000.000-00
                            VMasker(this).maskPattern('999.999.999-99');
                        } else {
                            // CNPJ mask: 00.000.000/0000-00
                            VMasker(this).maskPattern('99.999.999/9999-99');
                        }
                    });
                    // Trigger input event to apply mask to existing values
                    input.dispatchEvent(new Event('input'));
                });

                // Phone mask
                const phoneInputs = document.querySelectorAll('.phone-mask');
                phoneInputs.forEach(input => {
                    input.addEventListener('input', function() {
                        const value = this.value.replace(/\D/g, '');
                        if (value.length <= 10) {
                            // Landline phone: (00) 0000-0000
                            VMasker(this).maskPattern('(99) 9999-9999');
                        } else {
                            // Mobile phone: (00) 00000-0000
                            VMasker(this).maskPattern('(99) 99999-9999');
                        }
                    });
                    // Trigger input event to apply mask to existing values
                    input.dispatchEvent(new Event('input'));
                });

                // CEP (postal code) mask
                const cepInputs = document.querySelectorAll('.cep-mask');
                cepInputs.forEach(input => {
                    VMasker(input).maskPattern('99999-999');
                });
            }
        </script>

    {% endblock %}


{% endblock %}
